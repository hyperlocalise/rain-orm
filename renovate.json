{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "* * * * 1"
  ],
  "timezone": "Australia/Sydney",
  "packageRules": [
    {
      "description": "Group major Go module updates",
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "major Go package updates"
    },
    {
      "description": "Group minor and patch Go module updates",
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "minor Go package updates"
    }
  ]
}
